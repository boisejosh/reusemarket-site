---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="min-h-[70vh] flex items-center justify-center py-20 px-4">
    <div class="text-center max-w-lg">
      <p class="text-8xl font-heading font-bold mb-4" style="color: #e8f0e8;">404</p>
      <h1 class="text-3xl font-heading font-bold mb-4" style="color: #2d4a2d;">Page Not Found</h1>
      <p class="text-gray-600 mb-8 leading-relaxed">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-2.5 rounded-md font-semibold text-white transition-colors" style="background-color: #5a8a5a; min-width: 140px;" onmouseover="this.style.backgroundColor='#3d6b3d'" onmouseout="this.style.backgroundColor='#5a8a5a'">
          Go Home
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-2.5 rounded-md font-semibold border-2 transition-colors" style="border-color: #5a8a5a; color: #5a8a5a; min-width: 140px;" onmouseover="this.style.backgroundColor='#5a8a5a'; this.style.color='white';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#5a8a5a';">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
