---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with The ReUse Market in Garden City, Idaho. We'd love to hear from you about volunteering, donations, or any questions."
>

  <!-- Page Header -->
  <section class="py-14 md:py-20" style="background: linear-gradient(135deg, #2d4a2d 0%, #3d6b3d 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-green-300 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-green-100">Contact Us</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white">Contact Us</h1>
      <p class="mt-3 text-green-100 text-lg max-w-xl">We'd love to hear from you. Fill out the form and we'll get back to you promptly.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Form -->
      <div class="md:col-span-2">
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-6 reveal"
          novalidate
        >
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="Contact Form — The ReUse Market" />
          <input type="hidden" name="redirect" value="https://www.reusemarket.org/thank-you" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" aria-hidden="true" />

          <!-- Name row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-semibold mb-1.5" style="color: #2d4a2d;">First Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="first_name"
                name="first_name"
                required
                autocomplete="given-name"
                class="w-full px-4 py-2.5 rounded-md border text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                style="border-color: #d1d5db; background-color: white;"
              />
            </div>
            <div>
              <label for="last_name" class="block text-sm font-semibold mb-1.5" style="color: #2d4a2d;">Last Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="last_name"
                name="last_name"
                required
                autocomplete="family-name"
                class="w-full px-4 py-2.5 rounded-md border text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                style="border-color: #d1d5db; background-color: white;"
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold mb-1.5" style="color: #2d4a2d;">Email Address <span class="text-red-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-2.5 rounded-md border text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
              style="border-color: #d1d5db; background-color: white;"
            />
          </div>

          <!-- Subject -->
          <div>
            <label for="subject_topic" class="block text-sm font-semibold mb-1.5" style="color: #2d4a2d;">What is this about? <span class="text-red-500">*</span></label>
            <select
              id="subject_topic"
              name="subject_topic"
              required
              class="w-full px-4 py-2.5 rounded-md border text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
              style="border-color: #d1d5db; background-color: white;"
            >
              <option value="">Select a topic...</option>
              <option value="Volunteering">Volunteering</option>
              <option value="Material donation">Material donation</option>
              <option value="Monetary donation">Monetary donation</option>
              <option value="Business donation pickup">Business donation pickup</option>
              <option value="General question">General question</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold mb-1.5" style="color: #2d4a2d;">Message <span class="text-red-500">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2.5 rounded-md border text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-y"
              style="border-color: #d1d5db; background-color: white;"
              placeholder="How can we help?"
            ></textarea>
          </div>

          <div>
            <button
              type="submit"
              class="w-full sm:w-auto px-8 py-3 rounded-md font-semibold text-white transition-colors"
              style="background-color: #d97706; min-width: 200px;"
              onmouseover="this.style.backgroundColor='#b45309'"
              onmouseout="this.style.backgroundColor='#d97706'"
            >
              Send Message
            </button>
            <p class="mt-3 text-xs text-gray-400">We'll get back to you within one to two business days. Your information is never shared.</p>
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="rounded-xl p-6 reveal" style="background-color: #2d4a2d;">
          <h3 class="font-heading font-semibold text-white text-lg mb-4">Other ways to reach us</h3>
          <div class="space-y-4 text-sm text-green-200">
            <div>
              <p class="font-semibold text-white mb-0.5">Email</p>
              <a href="mailto:info@reusemarket.org" class="hover:text-white transition-colors">info@reusemarket.org</a>
            </div>
            <div>
              <p class="font-semibold text-white mb-0.5">Facebook</p>
              <a href="https://www.facebook.com/pages/The-ReUse-Market/157946281103" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">The ReUse Market</a>
            </div>
            <div>
              <p class="font-semibold text-white mb-0.5">In Person</p>
              <address class="not-italic text-green-200 leading-relaxed">
                3777 W Chinden Blvd.<br />
                Garden City, ID 83714<br />
                <span class="text-xs text-green-400">(upstairs in North End Organic Nursery)</span>
              </address>
            </div>
            <div>
              <p class="font-semibold text-white mb-0.5">Open Hours</p>
              <p class="text-green-200">Thu – Sat, Noon – 5:00 p.m.</p>
              <a href="/hours" class="text-xs text-green-400 hover:text-green-200 transition-colors">Hours vary — check before visiting</a>
            </div>
          </div>
        </div>

        <div class="rounded-xl p-6 reveal reveal-delay-1" style="background-color: #f2f7f2; border: 1px solid #e8f0e8;">
          <h3 class="font-heading font-semibold mb-3" style="color: #2d4a2d;">Looking to volunteer?</h3>
          <p class="text-sm text-gray-600 mb-4">Use our dedicated volunteer form for the fastest response.</p>
          <a href="/volunteer" class="inline-flex items-center justify-center px-5 py-2.5 rounded-md font-semibold text-white text-sm transition-colors w-full" style="background-color: #5a8a5a;" onmouseover="this.style.backgroundColor='#3d6b3d'" onmouseout="this.style.backgroundColor='#5a8a5a'">
            Volunteer Sign-Up Form
          </a>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
