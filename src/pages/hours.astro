---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Hours & Location"
  description="The ReUse Market is located at 3777 W Chinden Blvd., Garden City, Idaho — open Thursday through Saturday, noon to 5 p.m. Hours vary by volunteer availability."
>

  <!-- Page Header -->
  <section class="py-14 md:py-20" style="background: linear-gradient(135deg, #2d4a2d 0%, #3d6b3d 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-green-300 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-green-100">Hours & Location</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white">Hours & Location</h1>
      <p class="mt-3 text-green-100 text-lg max-w-xl">We're open when volunteers are available — always check before you visit.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Hours & Address -->
      <div class="space-y-6">

        <!-- Regular Hours -->
        <div class="rounded-xl p-8 reveal" style="background-color: #f2f7f2; border: 2px solid #e8f0e8;">
          <h2 class="text-2xl font-heading font-bold mb-5" style="color: #2d4a2d;">Regular Hours</h2>
          <div class="space-y-3">
            {[
              { day: 'Monday', hours: 'Closed' },
              { day: 'Tuesday', hours: 'Closed (Donation Drop-off: 10am–12:30pm)' },
              { day: 'Wednesday', hours: 'Closed' },
              { day: 'Thursday', hours: 'Noon – 5:00 p.m.' },
              { day: 'Friday', hours: 'Noon – 5:00 p.m.' },
              { day: 'Saturday', hours: 'Noon – 5:00 p.m.' },
              { day: 'Sunday', hours: 'Closed' },
            ].map((row) => (
              <div class={`flex justify-between items-center py-2.5 border-b text-sm ${row.hours.startsWith('Closed') ? 'text-gray-400' : 'text-gray-800'}`} style="border-color: #e8f0e8;">
                <span class={`font-medium ${row.hours === 'Closed' ? '' : 'font-semibold'}`} style={row.hours === 'Closed' ? '' : 'color: #2d4a2d;'}>{row.day}</span>
                <span class={row.hours === 'Closed' ? 'italic' : 'font-semibold text-green-700'}>{row.hours}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Important Note -->
        <div class="rounded-xl p-5 reveal reveal-delay-1" style="background-color: #fef3c7; border: 1px solid #fde68a;">
          <div class="flex items-start gap-3">
            <div class="text-xl flex-shrink-0">⚠️</div>
            <div>
              <p class="font-semibold mb-1 text-sm" style="color: #92400e;">Hours vary based on volunteer availability</p>
              <p class="text-xs text-amber-900 leading-relaxed">
                Because the market is entirely volunteer-operated, hours may change without notice. Please check our Facebook page or contact us before making a special trip.
              </p>
              <a href="https://www.facebook.com/pages/The-ReUse-Market/157946281103" target="_blank" rel="noopener noreferrer" class="mt-2 inline-block text-xs font-semibold underline" style="color: #92400e;">
                Check Facebook for updates →
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Address & Map -->
      <div class="space-y-6">

        <div class="rounded-xl p-8 reveal" style="background-color: #2d4a2d;">
          <h2 class="text-2xl font-heading font-bold text-white mb-5">Location</h2>
          <address class="text-green-100 not-italic leading-relaxed mb-4">
            <strong class="text-white text-lg block mb-1">The ReUse Market</strong>
            3777 W Chinden Blvd.<br />
            Garden City, ID 83714
          </address>
          <p class="text-green-200 text-sm mb-6">
            <span class="text-green-400">↑</span> Located <strong class="text-white">upstairs</strong> within the North End Organic Nursery building.
          </p>

          <!-- Directions links -->
          <div class="flex flex-col gap-3">
            <a
              href="https://maps.google.com/?q=3777+W+Chinden+Blvd+Garden+City+ID+83714"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-5 py-2.5 rounded-md font-semibold text-green-900 transition-colors"
              style="background-color: #fbbf24;"
              onmouseover="this.style.backgroundColor='#f59e0b'"
              onmouseout="this.style.backgroundColor='#fbbf24'"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Get Directions (Google Maps)
            </a>
            <a
              href="https://maps.apple.com/?q=3777+W+Chinden+Blvd+Garden+City+ID+83714"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-5 py-2.5 rounded-md font-semibold text-white border border-green-600 transition-colors hover:bg-green-700"
            >
              Get Directions (Apple Maps)
            </a>
          </div>
        </div>

        <!-- Map embed placeholder -->
        <div class="rounded-xl overflow-hidden reveal reveal-delay-1" style="border: 1px solid #e8f0e8; height: 260px; background-color: #f2f7f2; position: relative;">
          <iframe
            title="The ReUse Market location map"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2901.1!2d-116.238!3d43.641!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54aef8a5c3dddddd%3A0x0!2s3777+W+Chinden+Blvd%2C+Garden+City%2C+ID+83714!5e0!3m2!1sen!2sus!4v1"
            width="100%"
            height="260"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

        <div class="reveal reveal-delay-2">
          <h3 class="font-heading font-semibold mb-3" style="color: #2d4a2d;">Questions before you come?</h3>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact" class="inline-flex items-center justify-center px-5 py-2.5 rounded-md font-semibold text-white text-sm transition-colors" style="background-color: #5a8a5a;" onmouseover="this.style.backgroundColor='#3d6b3d'" onmouseout="this.style.backgroundColor='#5a8a5a'">
              Contact Us
            </a>
            <a href="mailto:info@reusemarket.org" class="inline-flex items-center justify-center px-5 py-2.5 rounded-md font-semibold text-sm border transition-colors" style="border-color: #5a8a5a; color: #5a8a5a;">
              info@reusemarket.org
            </a>
          </div>
        </div>

      </div>

    </div>
  </section>

</BaseLayout>
