---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Donate"
  description="Support The ReUse Market with a monetary donation or drop off clean, reusable art and craft materials. All donations are tax-deductible."
>

  <!-- Page Header -->
  <section class="py-14 md:py-20" style="background: linear-gradient(135deg, #2d4a2d 0%, #3d6b3d 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-green-300 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-green-100">Donate</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white">Donate</h1>
      <p class="mt-3 text-green-100 text-lg max-w-xl">All donations are tax-deductible. Thank you for supporting our mission.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Donate Money -->
      <div class="rounded-xl p-8 reveal" style="background-color: #fef3c7; border: 2px solid #fde68a;">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: #d97706;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <h2 class="text-2xl font-heading font-bold mb-3" style="color: #92400e;">Donate Money</h2>
        <p class="text-amber-900 leading-relaxed mb-6">
          Your tax-deductible monetary donation helps us maintain our space, support volunteers, and continue our mission to keep materials out of the landfill.
        </p>

        <!-- PayPal Button Placeholder -->
        <div class="rounded-lg p-6 text-center border-2 border-dashed" style="border-color: #f59e0b; background-color: rgba(245,158,11,0.05);">
          <p class="text-sm font-semibold mb-2" style="color: #92400e;">Secure Donation via PayPal</p>
          <p class="text-xs text-amber-700 mb-4">PayPal donation button will be placed here.</p>
          <!-- TODO: Replace this placeholder with your PayPal donation button embed code -->
          <div class="inline-flex items-center gap-2 px-6 py-3 rounded-md font-semibold text-white cursor-not-allowed opacity-60" style="background-color: #0070ba;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.076 21.337H2.47a.641.641 0 01-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 00-.607-.541c-.013.076-.026.175-.041.254-.59 3.025-2.566 6.059-7.428 6.059H10.96l-1.17 7.409h3.028c.458 0 .846-.334.918-.787l.038-.196.73-4.625.047-.254a.93.93 0 01.918-.788h.578c3.741 0 6.67-1.52 7.523-5.914.36-1.847.174-3.39-.568-4.617z"/>
            </svg>
            Donate with PayPal
          </div>
          <p class="mt-3 text-xs text-amber-600 italic">Button coming soon</p>
        </div>

        <p class="mt-4 text-xs text-amber-700">
          The ReUse Market is a 501(c)(3) nonprofit. Your donation is tax-deductible to the full extent of the law.
        </p>
      </div>

      <!-- Donate Materials -->
      <div class="rounded-xl p-8 reveal reveal-delay-1" style="background-color: #f2f7f2; border: 2px solid #e8f0e8;">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: #5a8a5a;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-heading font-bold mb-3" style="color: #2d4a2d;">Donate Materials</h2>

        <div class="mb-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-semibold" style="background-color: #dcfce7; color: #166534;">
          <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>
          Material donations are currently ACCEPTED
        </div>

        <p class="text-gray-700 leading-relaxed mb-4">
          Drop off materials on <strong>Tuesdays, 10 a.m. to 12:30 p.m.</strong> Please check our <a href="/hours" class="underline" style="color: #5a8a5a;">Hours of Operation calendar</a> to confirm we are open.
        </p>

        <div class="rounded-lg p-4 mb-4 text-sm text-gray-700" style="background-color: #e8f0e8; border-left: 3px solid #5a8a5a;">
          <p class="font-semibold mb-1" style="color: #2d4a2d;">Drop-off guidelines:</p>
          <ul class="space-y-1 text-gray-600">
            <li>• Materials must be <strong>clean and in good condition</strong></li>
            <li>• Limit of <strong>two boxes</strong> per month when dropping off</li>
            <li>• Larger donations? <a href="/contact" class="underline" style="color: #5a8a5a;">Contact us</a> to schedule a pickup</li>
          </ul>
        </div>

        <a href="/donate/guidelines" class="inline-flex items-center gap-1 text-sm font-semibold transition-colors" style="color: #5a8a5a;">
          View full donation guidelines →
        </a>
      </div>

    </div>

    <!-- Business Donations -->
    <div class="mt-10 rounded-xl p-8 reveal" style="background-color: #2d4a2d;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-2xl font-heading font-bold text-white mb-4">Are you a business?</h2>
          <p class="text-green-100 leading-relaxed">
            We encourage local businesses — sign companies, print shops, fabric stores, flooring stores, and more — with clean, reusable scrap materials to contact us. We offer a <strong class="text-white">monthly pickup service</strong> for businesses.
          </p>
          <ul class="mt-4 space-y-2 text-green-200 text-sm">
            <li class="flex items-start gap-2"><span class="text-green-400">✓</span><span>Tax-deductible receipt provided</span></li>
            <li class="flex items-start gap-2"><span class="text-green-400">✓</span><span>Your business publicly recognized on our website</span></li>
            <li class="flex items-start gap-2"><span class="text-green-400">✓</span><span>We handle the logistics — you just have the materials ready</span></li>
          </ul>
        </div>
        <div class="text-center">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 rounded-md font-semibold text-green-900 transition-colors w-full sm:w-auto" style="background-color: #fbbf24; min-width: 220px;" onmouseover="this.style.backgroundColor='#f59e0b'" onmouseout="this.style.backgroundColor='#fbbf24'">
            Contact Us About Business Donations
          </a>
        </div>
      </div>
    </div>

    <!-- Individual Donations -->
    <div class="mt-8 rounded-xl p-6 reveal" style="background-color: #f2f7f2; border: 1px solid #e8f0e8;">
      <div class="flex items-start gap-4">
        <div class="text-2xl flex-shrink-0">🏠</div>
        <div>
          <h3 class="font-heading font-semibold text-lg mb-2" style="color: #2d4a2d;">Cleaning out your craft closet?</h3>
          <p class="text-gray-700 text-sm leading-relaxed">
            If you're decluttering and have art or craft-related materials, we'd love to give them a new home. Check our <a href="/donate/guidelines" class="underline font-medium" style="color: #5a8a5a;">donation guidelines</a> to see what we accept, then drop them off during our Tuesday donation hours.
          </p>
        </div>
      </div>
    </div>

  </section>

</BaseLayout>
