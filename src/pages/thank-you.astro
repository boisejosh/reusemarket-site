---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Thank you for reaching out to The ReUse Market. We'll be in touch soon."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 px-4">
    <div class="text-center max-w-lg">
      <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background-color: #f2f7f2;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#5a8a5a" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h1 class="text-4xl font-heading font-bold mb-4" style="color: #2d4a2d;">Thank You!</h1>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        Your message has been sent. We'll get back to you within one to two business days.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-2.5 rounded-md font-semibold text-white transition-colors" style="background-color: #5a8a5a; min-width: 160px;" onmouseover="this.style.backgroundColor='#3d6b3d'" onmouseout="this.style.backgroundColor='#5a8a5a'">
          Back to Home
        </a>
        <a href="/news" class="inline-flex items-center justify-center px-6 py-2.5 rounded-md font-semibold border-2 transition-colors" style="border-color: #5a8a5a; color: #5a8a5a; min-width: 160px;" onmouseover="this.style.backgroundColor='#5a8a5a'; this.style.color='white';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#5a8a5a';">
          News & Events
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
