---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Donation Guidelines"
  description="What The ReUse Market does and does not accept as material donations. All items must be clean and in good condition."
>

  <!-- Page Header -->
  <section class="py-14 md:py-20" style="background: linear-gradient(135deg, #2d4a2d 0%, #3d6b3d 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-green-300 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/donate" class="hover:text-white transition-colors">Donate</a>
        <span class="mx-2">/</span>
        <span class="text-green-100">Donation Guidelines</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white">Donation Guidelines</h1>
      <p class="mt-3 text-green-100 text-lg max-w-xl">What we accept — and what we can't. All donations must be clean and in good condition.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">

    <!-- Important note -->
    <div class="rounded-xl p-5 mb-10 flex items-start gap-4 reveal" style="background-color: #fef3c7; border: 1px solid #fde68a;">
      <div class="text-2xl flex-shrink-0">⚠️</div>
      <div>
        <p class="font-semibold mb-1" style="color: #92400e;">Before you drop off:</p>
        <p class="text-sm text-amber-900">
          Please ensure all materials are <strong>clean</strong>, dry, and in usable condition. Items that are soiled, broken, or not on our accepted list will not be taken. We accept donations <strong>Tuesdays, 10 a.m. – 12:30 p.m.</strong> — no more than two boxes per visit. <a href="/contact" class="underline font-medium" style="color: #92400e;">Contact us</a> for larger donations or to schedule a pickup.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- We Accept -->
      <div class="reveal">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #5a8a5a;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h2 class="text-2xl font-heading font-bold" style="color: #2d4a2d;">We Accept</h2>
        </div>

        <div class="space-y-4">
          {[
            {
              category: 'Fabric & Textiles',
              items: ['Fabric scraps and yardage', 'Ribbon, trim, and lace', 'Yarn and thread', 'Felt', 'Sewing notions (buttons, zippers, snaps)', 'Upholstery and drapery samples'],
            },
            {
              category: 'Paper & Cardboard',
              items: ['Cardstock and specialty paper', 'Foam board and mat board', 'Cardboard scraps (clean)', 'Wallpaper samples', 'Wrapping paper (unused)'],
            },
            {
              category: 'Art Supplies',
              items: ['Brushes and painting tools', 'Acrylic, watercolor, and oil paint (unused/usable)', 'Markers and pens (working)', 'Drawing and sketching supplies', 'Canvas and painting surfaces'],
            },
            {
              category: 'Craft Materials',
              items: ['Beads, buttons, and embellishments', 'Wire and metal findings', 'Foam shapes and sheets', 'Mosaic tiles', 'Decorative elements', 'Mixed media supplies'],
            },
            {
              category: 'Design & Trade Samples',
              items: ['Tile and flooring samples', 'Interior design fabric swatches', 'Paint chip collections', 'Laminate samples', 'Wallpaper books'],
            },
          ].map((group) => (
            <div class="rounded-lg overflow-hidden" style="border: 1px solid #e8f0e8;">
              <div class="px-4 py-2.5 font-semibold text-sm text-white" style="background-color: #5a8a5a;">
                {group.category}
              </div>
              <ul class="px-4 py-3 space-y-1">
                {group.items.map((item) => (
                  <li class="text-sm text-gray-700 flex items-start gap-2">
                    <span class="text-green-500 mt-0.5 flex-shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- We Do Not Accept -->
      <div class="reveal reveal-delay-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #dc2626;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </div>
          <h2 class="text-2xl font-heading font-bold" style="color: #991b1b;">We Do Not Accept</h2>
        </div>

        <div class="rounded-xl p-6 mb-6" style="background-color: #fef2f2; border: 1px solid #fecaca;">
          <ul class="space-y-3">
            {[
              'Soiled, stained, or wet materials of any kind',
              'Broken tools or supplies',
              'Hazardous materials (solvents, aerosols, toxic paints)',
              'General household clutter, clothing, or non-craft items',
              'Used or opened food items',
              'Electronics of any kind',
              'Furniture',
              'Items in poor or unusable condition',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-red-900">
                <span class="text-red-400 mt-0.5 flex-shrink-0">✗</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-6" style="background-color: #f2f7f2; border: 1px solid #e8f0e8;">
          <h3 class="font-heading font-semibold mb-3" style="color: #2d4a2d;">Not sure if we'll take it?</h3>
          <p class="text-sm text-gray-700 leading-relaxed mb-4">
            If you have something not on this list, just email us and we'll let you know whether we can take it.
          </p>
          <a href="mailto:info@reusemarket.org" class="text-sm font-semibold underline" style="color: #5a8a5a;">
            info@reusemarket.org
          </a>
        </div>

        <!-- Drop-off info box -->
        <div class="mt-6 rounded-xl p-6" style="background-color: #fef3c7; border: 1px solid #fde68a;">
          <h3 class="font-heading font-semibold mb-3" style="color: #92400e;">Drop-Off Hours</h3>
          <p class="text-sm text-amber-900 leading-relaxed mb-2">
            <strong>Tuesdays, 10:00 a.m. – 12:30 p.m.</strong>
          </p>
          <p class="text-sm text-amber-800">
            3777 W Chinden Blvd., Garden City, ID 83714<br />
            (upstairs in North End Organic Nursery)
          </p>
          <p class="mt-3 text-xs text-amber-700">
            Please check our <a href="/hours" class="underline font-medium" style="color: #92400e;">Hours & Location page</a> before coming to confirm we are open.
          </p>
        </div>
      </div>

    </div>

    <!-- Back to donate -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="/donate" class="text-sm font-semibold transition-colors" style="color: #5a8a5a;">
        ← Back to Donate
      </a>
    </div>

  </section>

</BaseLayout>
