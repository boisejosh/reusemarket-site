---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The ReUse Market is a Boise, Idaho nonprofit that collects clean, reusable art and craft materials and puts them into the hands of artists, teachers, and crafters.',
  canonical,
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const siteUrl = 'https://www.reusemarket.org';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title === 'Home' ? 'The ReUse Market — Boise, Idaho' : `${title} | The ReUse Market`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:site_name" content="The ReUse Market" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/favicon.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "The ReUse Market",
    "description": "A Boise, Idaho nonprofit redirecting scrap art and craft materials for creative reuse.",
    "@id": "https://www.reusemarket.org",
    "url": "https://www.reusemarket.org",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3777 W Chinden Blvd.",
      "addressLocality": "Garden City",
      "addressRegion": "ID",
      "postalCode": "83714",
      "addressCountry": "US"
    },
    "openingHours": ["Th 12:00-17:00", "Fr 12:00-17:00", "Sa 12:00-17:00"],
    "areaServed": ["Boise", "Garden City", "Meridian", "Nampa"],
    "sameAs": ["https://www.facebook.com/pages/The-ReUse-Market/157946281103"]
  }
  </script>
</head>
<body class="pb-20 md:pb-0">

  <!-- Skip to content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Navigation -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-green-100 shadow-sm" role="banner">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6" aria-label="Main navigation">
      <div class="flex items-center justify-between h-16">

        <!-- Logo / Wordmark -->
        <a href="/" class="flex items-center gap-2 group" aria-label="The ReUse Market — Home">
          <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #5a8a5a;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="white"/>
              <path d="M7 11l5-5 5 5" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 6v10" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M8 9.5C8 9.5 10 11 12 10s4-3 4-3" stroke="white" stroke-width="1" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-heading font-semibold text-lg leading-tight" style="color: #2d4a2d;">
            The <span style="color: #5a8a5a;">ReUse</span> Market
          </span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-1" role="list">
          <a href="/about" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">About</a>
          <a href="/the-market" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">@ The Market</a>
          <a href="/news" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">News & Events</a>
          <a href="/volunteer" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">Volunteer</a>
          <a href="/donate" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">Donate</a>
          <a href="/hours" class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:text-green-700 hover:bg-green-50 transition-colors">Hours</a>
          <a href="/contact" class="ml-2 px-4 py-2 rounded-md text-sm font-semibold text-white transition-colors" style="background-color: #d97706;" onmouseover="this.style.backgroundColor='#b45309'" onmouseout="this.style.backgroundColor='#d97706'">Contact Us</a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden p-2 rounded-md text-gray-600 hover:text-green-700 hover:bg-green-50 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open navigation menu"
        >
          <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-green-100 py-3" role="menu">
        <a href="/about" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">About</a>
        <a href="/the-market" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">@ The Market</a>
        <a href="/news" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">News & Events</a>
        <a href="/volunteer" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">Volunteer</a>
        <a href="/donate" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">Donate</a>
        <a href="/hours" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">Hours & Location</a>
        <a href="/contact" class="block px-4 py-3 text-lg font-semibold text-gray-700 hover:text-green-700 hover:bg-green-50 rounded-md transition-colors" role="menuitem">Contact Us</a>
      </div>
    </nav>
  </header>

  <!-- Main content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-20 border-t border-green-100" style="background-color: #2d4a2d;" role="contentinfo">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

        <!-- Brand column -->
        <div>
          <a href="/" class="inline-flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-full flex items-center justify-center" style="background-color: #5a8a5a;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M7 11l5-5 5 5" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 6v10" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="font-heading font-semibold text-white">The ReUse Market</span>
          </a>
          <p class="text-sm text-green-200 leading-relaxed">
            Redirecting scrap materials for creative reuse. A Boise, Idaho 501(c)(3) nonprofit.
          </p>
          <p class="mt-4 text-sm text-green-300">
            <a href="https://www.facebook.com/pages/The-ReUse-Market/157946281103" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Follow us on Facebook</a>
          </p>
        </div>

        <!-- Quick links -->
        <div>
          <h3 class="font-heading font-semibold text-white mb-4">Quick Links</h3>
          <ul class="space-y-2 text-sm text-green-200">
            <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
            <li><a href="/the-market" class="hover:text-white transition-colors">@ The Market</a></li>
            <li><a href="/news" class="hover:text-white transition-colors">News & Events</a></li>
            <li><a href="/volunteer" class="hover:text-white transition-colors">Volunteer</a></li>
            <li><a href="/donate" class="hover:text-white transition-colors">Donate</a></li>
            <li><a href="/donate/guidelines" class="hover:text-white transition-colors">Donation Guidelines</a></li>
          </ul>
        </div>

        <!-- Hours & Contact -->
        <div>
          <h3 class="font-heading font-semibold text-white mb-4">Visit Us</h3>
          <address class="text-sm text-green-200 not-italic leading-relaxed">
            <strong class="text-white">Location:</strong><br />
            3777 W Chinden Blvd.<br />
            Garden City, ID 83714<br />
            <span class="text-green-300 text-xs">(upstairs in North End Organic Nursery)</span>
          </address>
          <p class="mt-3 text-sm text-green-200">
            <strong class="text-white">Hours:</strong><br />
            Thu – Sat, Noon to 5 p.m.<br />
            <span class="text-green-300 text-xs">Hours vary — <a href="/hours" class="underline hover:text-white">check calendar</a> before visiting.</span>
          </p>
          <p class="mt-3 text-sm text-green-200">
            <a href="mailto:info@reusemarket.org" class="hover:text-white transition-colors">info@reusemarket.org</a>
          </p>
        </div>
      </div>

      <div class="mt-10 pt-6 border-t border-green-800 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-green-400">
        <p>&copy; {new Date().getFullYear()} The ReUse Market. All Rights Reserved. A 501(c)(3) organization.</p>
        <div class="flex gap-4">
          <a href="/contact" class="hover:text-green-200 transition-colors">Contact</a>
          <a href="/hours" class="hover:text-green-200 transition-colors">Hours & Location</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Sticky mobile CTA bar -->
  <div id="mobile-cta" class="md:hidden fixed bottom-0 left-0 right-0 z-40 flex border-t border-green-200 shadow-lg" style="background-color: white; transform: translateY(100%); animation: slideUp 0.5s ease-out 1s forwards;">
    <a href="/volunteer" class="flex-1 py-4 text-center text-sm font-semibold text-white transition-colors" style="background-color: #5a8a5a;">
      Volunteer
    </a>
    <a href="/donate" class="flex-1 py-4 text-center text-sm font-semibold text-white transition-colors" style="background-color: #d97706;">
      Donate
    </a>
  </div>

  <style>
    @keyframes slideUp {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }
  </style>

  <!-- Scripts -->
  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', !isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen!);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });

    // Scroll reveal
    const reveals = document.querySelectorAll('.reveal');
    if (reveals.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
      );
      reveals.forEach((el) => observer.observe(el));
    }

    // Hide mobile CTA bar on contact/volunteer/donate pages
    const path = window.location.pathname;
    if (['/contact', '/volunteer', '/donate'].includes(path)) {
      const cta = document.getElementById('mobile-cta');
      if (cta) cta.style.display = 'none';
      document.body.style.paddingBottom = '0';
    }
  </script>
</body>
</html>
